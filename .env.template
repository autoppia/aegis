# Aegis — Policy enforcement for AI coding agents
# Copy this to .env and fill in what you need.

# ─── API Keys (only needed for non-deterministic rules) ─────────────
# Deterministic rules (tool calls, resource limits) need NO API key.
# Non-deterministic rules (profanity, tone, etc.) require one for the
# POLICY_MODEL — an LLM-as-judge that evaluates content at runtime.

# OpenAI — POLICY_MODEL defaults to gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Anthropic — POLICY_MODEL defaults to claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# ─── POLICY_MODEL (optional overrides) ──────────────────────────────
# Override to use a custom or fine-tuned model:
# AEGIS_POLICY_MODEL=your-model-name
# AEGIS_POLICY_MODEL_BASE_URL=https://your-endpoint.com/v1
